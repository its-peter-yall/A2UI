# A2UI Server Environment Configuration
# ========================================
#
# This application uses OpenRouter as its LLM provider.
# API keys are supplied per-request from the frontend (user-provided),
# so no server-side OPENROUTER_API_KEY is required for normal use.
#
# The frontend sends the user's key via the X-OpenRouter-Key header
# on every request that needs LLM access.

# OpenRouter base URL (optional - defaults to https://openrouter.ai/api/v1)
# Uncomment and change only if using a custom proxy or self-hosted endpoint.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Request timeout in seconds for OpenRouter API calls (optional - default 60)
# OPENROUTER_TIMEOUT_SECONDS=60
